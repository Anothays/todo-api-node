{
  "openapi": "3.0.0",
  "info": {
    "title": "Todo API",
    "version": "1.0.0"
  },
  "paths": {
    "/todos": {
      "get": {
        "summary": "Récupérer tous les todos",
        "parameters": [
          { "name": "skip", "in": "query", "schema": { "type": "integer", "default": 0 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 10 } }
        ],
        "responses": {
          "200": { "description": "Liste des todos" }
        }
      },
      "post": {
        "summary": "Créer un todo",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["title"],
                "properties": {
                  "title": { "type": "string" },
                  "description": { "type": "string" },
                  "status": { "type": "string", "default": "pending" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Todo créé" },
          "422": { "description": "title manquant" }
        }
      }
    },
    "/todos/search/all": {
      "get": {
        "summary": "Rechercher des todos par titre",
        "parameters": [
          { "name": "q", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Résultats de la recherche" }
        }
      }
    },
    "/todos/{id}": {
      "get": {
        "summary": "Récupérer un todo par ID",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Todo trouvé" },
          "404": { "description": "Todo non trouvé" }
        }
      },
      "put": {
        "summary": "Mettre à jour un todo",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": { "type": "string" },
                  "description": { "type": "string" },
                  "status": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Todo mis à jour" },
          "404": { "description": "Todo non trouvé" }
        }
      },
      "delete": {
        "summary": "Supprimer un todo",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Todo supprimé" },
          "404": { "description": "Todo non trouvé" }
        }
      }
    }
  }
}